# =============================================================================
# Secrets file for plex_dbrepair deployment.
#
# Copy this file to `.secrets` (same directory) and fill in real values.
# `.secrets` is gitignored. Never commit it.
#
# Format: KEY=value (one per line). Optional surrounding quotes are stripped.
# Blank lines and lines starting with # are ignored. The first `=` separates
# the key from the value, so values may contain `=` themselves.
#
# deploy.ps1 reads this file and writes the values into the matching
# assignment lines at the top of `script`, then pushes the result to
# the Unraid flash share over SMB.
# =============================================================================

# Docker container name for Plex Media Server
PLEX_CONTAINER=plex

# Plex authentication token
# Find yours at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=your-plex-token-here

# Plex port (default: 32400)
PLEX_PORT=32400

# Host path where DBRepair.sh will be downloaded.
# Use /mnt/cache/... (or /mnt/<pool-name>/...) to bypass the Unraid FUSE/SHFS
# layer. Avoid /mnt/user/ — it routes through shfs and adds overhead.
DBREPAIR_HOST_PATH=/mnt/cache/appdata/PlexMediaServer/DBRepair.sh

# Path inside the container where DBRepair.sh will be copied
DBREPAIR_CONTAINER_PATH=/config/DBRepair.sh

# GitHub release URL for DBRepair.sh (leave as-is unless self-hosting)
DBREPAIR_URL=https://github.com/ChuckPa/PlexDBRepair/releases/latest/download/DBRepair.sh

# Path for the maintenance log file on the host (also bypass FUSE — use /mnt/cache/...)
LOG_FILE=/mnt/cache/appdata/PlexMediaServer/dbrepair_schedule.log

# Discord webhook URL for notifications (leave empty to disable)
# Create one at: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK=
